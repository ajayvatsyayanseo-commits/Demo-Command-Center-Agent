# Application (non-secret values are deployment-specific)
APP_ENV=local
APP_NAME=demo-command-center-agent
APP_VERSION=
LOG_LEVEL=INFO
APP_DEBUG=false
MAX_REQUEST_BODY_BYTES=1048576
CORS_ALLOWED_ORIGINS=[]
ALLOWED_HOSTS=["localhost","testserver"]
PUBLIC_BASE_URL=
INTERNAL_BASE_URL=
DEFAULT_TIMEZONE=
DEFAULT_LOCALE=
TENANT_ID=
PROVIDER_PROFILE=local

# PostgreSQL
DATABASE_URL=
DB_POOL_MIN=
DB_POOL_MAX=
DB_CONNECT_TIMEOUT=
DB_STATEMENT_TIMEOUT=
DB_REQUIRE_TLS=true
FIELD_ENCRYPTION_KEY=
FIELD_ENCRYPTION_KEY_REFERENCE=
AUDIT_HASH_KEY=
AUDIT_HASH_KEY_REFERENCE=

# Redis
REDIS_URL=
CACHE_DEFAULT_TTL_SECONDS=
LOCK_DEFAULT_TTL_SECONDS=

# AWS
AWS_REGION=
AWS_ACCOUNT_ID=
SQS_INBOUND_QUEUE_URL=
SQS_SCHEDULING_QUEUE_URL=
SQS_OUTBOUND_QUEUE_URL=
SQS_REMINDERS_QUEUE_URL=
SQS_PAYMENTS_QUEUE_URL=
SQS_ANALYTICS_QUEUE_URL=
SQS_MODEL_EVALUATION_QUEUE_URL=
SQS_HUMAN_HANDOFF_QUEUE_URL=
S3_ANALYTICS_BUCKET=
S3_MODEL_BUCKET=
SES_FROM_ADDRESS=
AWS_SECRETS_PREFIX=
KMS_KEY_ARN=
EVENTBRIDGE_SCHEDULE_GROUP=
OTEL_EXPORTER_OTLP_ENDPOINT=
CLOUDWATCH_NAMESPACE=

# Meta WhatsApp - all credential values stay empty in source control
META_GRAPH_API_VERSION=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_TEMPLATE_LANGUAGE=
META_DIRECT_WEBHOOK_ENABLED=false
META_OUTBOUND_ENABLED=false
META_OUTBOUND_PAUSED=true

# Agent harmony
LEAD_INTAKE_BASE_URL=
LEAD_INTAKE_AUTH_MODE=
LEAD_INTAKE_SHARED_SECRET=
LEAD_INTAKE_TIMEOUT_SECONDS=
ONBOARDING_AGENT_BASE_URL=
ONBOARDING_AGENT_AUTH_MODE=
ONBOARDING_AGENT_SHARED_SECRET=
ONBOARDING_AGENT_TIMEOUT_SECONDS=
ONBOARDING_HANDOFF_POLICY_REFERENCE=
MESSAGE_POLICY_REFERENCE=
WELCOME_TEMPLATE_REFERENCE=
WELCOME_MESSAGE_VERSION=
OUTBOUND_MESSAGE_GATEWAY_BASE_URL=
INTERNAL_JWT_ISSUER=
INTERNAL_JWT_AUDIENCE=
INTERNAL_SIGNING_KEY_ID=

# JSON object keyed by inbound key ID; each grant contains secret, source, and allowed scopes.
INTERNAL_HMAC_KEY_GRANTS={}
INTERNAL_REPLAY_WINDOW_SECONDS=
INTERNAL_AUTH_ISSUER=nxtutors-internal
INTERNAL_AUTH_AUDIENCE=demo-command-center
INTERNAL_LEGACY_SHARED_SECRET_ENABLED=true

# Website integration gateway
# Laravel/MySQL credentials stay in the Laravel website deployment. This service reads
# register/tutor data only through NXTUTORS_WEBSITE_INTERNAL_BASE_URL.
NXTUTORS_WEBSITE_BASE_URL=
NXTUTORS_WEBSITE_INTERNAL_BASE_URL=
NXTUTORS_WEBSITE_AUTH_MODE=
NXTUTORS_WEBSITE_SHARED_SECRET=
NXTUTORS_WEBSITE_TIMEOUT_SECONDS=

# NXTutors Laravel/MySQL access used by the website gateway adapter deployment only.
# Do not wire these values into Demo Command Center Python code; the agent must read
# register/tutor data through the authenticated NXTUTORS_WEBSITE_INTERNAL_BASE_URL gateway.
NXTUTORS_WEBSITE_DB_CONNECTION=mysql
NXTUTORS_WEBSITE_DB_HOST=127.0.0.1
NXTUTORS_WEBSITE_DB_PORT=3306
NXTUTORS_WEBSITE_DB_DATABASE=
NXTUTORS_WEBSITE_DB_USERNAME=
NXTUTORS_WEBSITE_DB_PASSWORD=
NXTUTORS_WEBSITE_DB_SSL_CA=
NXTUTORS_WEBSITE_DB_READ_ONLY=true
NXTUTORS_WEBSITE_REGISTER_TABLE=register

# Google Calendar/Meet
GOOGLE_CALENDAR_AUTH_MODE=
GOOGLE_CALENDAR_ID=
GOOGLE_WORKSPACE_DELEGATED_USER=
GOOGLE_CREDENTIAL_SECRET_ARN=
GOOGLE_CALENDAR_SCOPES=
GOOGLE_MEET_ENABLED=false

# Cashfree
CASHFREE_ENV=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_API_VERSION=
CASHFREE_TIMEOUT_SECONDS=
CASHFREE_WEBHOOK_REPLAY_WINDOW_SECONDS=
CASHFREE_PAYMENT_LINK_ENABLED=false
CASHFREE_ORDER_ENABLED=false

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EXTRACTION_MODEL=
OPENAI_DRAFTING_MODEL=
OPENAI_REQUEST_TIMEOUT_SECONDS=
OPENAI_MAX_RETRIES=
OPENAI_MAX_INPUT_TOKENS=
OPENAI_MAX_OUTPUT_TOKENS=
OPENAI_DAILY_BUDGET=
OPENAI_MONTHLY_BUDGET=
OPENAI_ENABLED=false

# Policy references/values are supplied per environment or policy records
REMINDER_POLICY_REFERENCE=
QUIET_HOURS_POLICY_REFERENCE=
SLOT_HOLD_TTL_SECONDS=
CONFIRMATION_TTL_SECONDS=
DISCOUNT_POLICY_SOURCE=
PAYMENT_EXPIRY_SECONDS=
RATE_LIMIT_POLICY_REFERENCE=
RETRY_POLICY_REFERENCE=
RETENTION_POLICY_REFERENCE=
EVALUATION_POLICY_REFERENCE=
EVALUATION_WINDOW_DAYS=
EVALUATION_MIN_SAMPLES=
FORECAST_BRIER_THRESHOLD=
FORECAST_CALIBRATION_ERROR_THRESHOLD=
PAYMENT_RECONCILE_DELAY_SECONDS=
PAYMENT_RECONCILIATION_POLICY_REFERENCE=
EVALUATION_POSITIVE_OUTCOMES=[]

# Feature flags and kill switches
DEMO_COMMAND_CENTER_ENABLED=true
DEMO_SCHEDULING_ENABLED=false
DEMO_REMINDERS_ENABLED=false
DEMO_FORECASTING_ENABLED=false
DEMO_OBJECTION_EXTRACTION_ENABLED=false
DEMO_POST_CONVERSION_ENABLED=false
DEMO_DISCOUNTS_ENABLED=false
DEMO_PAYMENTS_ENABLED=false
DEMO_OUTBOUND_PAUSED=true
DEMO_NEW_BOOKINGS_PAUSED=true
DEMO_GOOGLE_MEET_ENABLED=false
DEMO_OPENAI_ENABLED=false
DEMO_AUTOMATIC_DISCOUNT_ENABLED=false
DEMO_AUTOMATIC_PAYMENT_LINK_ENABLED=false
RETENTION_CLEANUP_ENABLED=false
PAYMENT_RECONCILIATION_ENABLED=false
MODEL_EVALUATION_ENABLED=false
DLQ_REDRIVE_ENABLED=false
