{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.nxtutors.internal/demo-command-center/lead-intake/outbound-delivery-requested.v1.schema.json",
  "title": "Canonical Lead Intake outbound WhatsApp request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "demo_id",
    "recipient_ref",
    "template_or_message_ref",
    "variables",
    "message_category",
    "service_window_expires_at",
    "send_key",
    "correlation_id"
  ],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_type": {"const": "outbound.delivery.requested.v1"},
    "demo_id": {"type": "string", "format": "uuid"},
    "recipient_ref": {"type": "string", "minLength": 1, "maxLength": 255},
    "template_or_message_ref": {"type": "string", "minLength": 1, "maxLength": 255},
    "variables": {
      "type": "object",
      "maxProperties": 50,
      "additionalProperties": {"type": "string"}
    },
    "message_category": {"enum": ["service", "utility", "marketing"]},
    "service_window_expires_at": {"type": "string", "format": "date-time"},
    "send_key": {"type": "string", "minLength": 8, "maxLength": 255},
    "correlation_id": {"type": "string", "minLength": 1, "maxLength": 128}
  }
}
