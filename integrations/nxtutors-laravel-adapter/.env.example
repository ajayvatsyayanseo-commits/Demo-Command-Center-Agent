# Laravel website deployment values. Keep real credentials out of source control.
APP_ENV=production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSL_CA=

# Legacy website table names. Keep `register` as the authoritative profile/tutor source unless the
# Laravel installation has renamed it and the adapter config has been reviewed.
DEMO_COMMAND_CENTER_TABLE_REGISTER=register
DEMO_COMMAND_CENTER_TABLE_COURSE_MANAGEMENT=teacher_course_managment
DEMO_COMMAND_CENTER_TABLE_TEACHER_COURSES=teacher_courses
DEMO_COMMAND_CENTER_TABLE_REVIEWS=teacher_review
DEMO_COMMAND_CENTER_TABLE_PLANS=subscription_plans
DEMO_COMMAND_CENTER_TABLE_SUBSCRIPTIONS=user_subscriptions
DEMO_COMMAND_CENTER_TABLE_ORDERS=order_managment
DEMO_COMMAND_CENTER_TABLE_DEMO_LEADS=demo_leads

# Demo Command Center gateway package
DEMO_COMMAND_CENTER_GATEWAY_ENABLED=false
DEMO_COMMAND_CENTER_HMAC_KEYS_JSON={}
DEMO_COMMAND_CENTER_HMAC_SOURCE=demo-command-center
DEMO_COMMAND_CENTER_HMAC_AUDIENCE=nxtutors-website-gateway
DEMO_COMMAND_CENTER_REPLAY_WINDOW_SECONDS=300
DEMO_COMMAND_CENTER_MAX_CLOCK_SKEW_SECONDS=30
DEMO_COMMAND_CENTER_MAX_BODY_BYTES=65536
DEMO_COMMAND_CENTER_RATE_LIMIT_PER_MINUTE=120
DEMO_COMMAND_CENTER_AUDIT_REQUIRED=true
DEMO_COMMAND_CENTER_AUDIT_IP_HASH_KEY=
DEMO_COMMAND_CENTER_DEFAULT_CURRENCY=INR
DEMO_COMMAND_CENTER_IDEMPOTENCY_RETENTION_HOURS=168
DEMO_COMMAND_CENTER_REGION_MAPPING_VERSION=
DEMO_COMMAND_CENTER_SUBSCRIPTION_ACTIVE_STATUS=
DEMO_COMMAND_CENTER_SUBSCRIPTION_PAID_STATUS=
DEMO_COMMAND_CENTER_SUBSCRIPTION_TYPE=
