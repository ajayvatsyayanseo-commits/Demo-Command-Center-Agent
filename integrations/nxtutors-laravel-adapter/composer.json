{
  "name": "nxtutors/demo-command-center-adapter",
  "description": "Private, authenticated Laravel integration gateway for Demo Command Center",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "illuminate/cache": "^12.0",
    "illuminate/config": "^12.0",
    "illuminate/database": "^12.0",
    "illuminate/http": "^12.0",
    "illuminate/routing": "^12.0",
    "illuminate/support": "^12.0",
    "illuminate/validation": "^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {"psr-4": {"NxTutors\\DemoCommandCenterAdapter\\": "app/"}},
  "autoload-dev": {"psr-4": {"NxTutors\\DemoCommandCenterAdapter\\Tests\\": "tests/"}},
  "extra": {
    "laravel": {
      "providers": [
        "NxTutors\\DemoCommandCenterAdapter\\DemoCommandCenterAdapterServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {"php-http/discovery": false}
  },
  "scripts": {
    "test": "phpunit --colors=always"
  }
}
