--- a/.github/workflows/deploy-prod.yml
+++ b/.github/workflows/deploy-prod.yml
@@ -1,5 +1,9 @@
 name: Deploy Production
 on:
+  # ADDED: Optimize triggers to prevent unnecessary runs
+  push:
+    branches: [main]
+    paths:
+      - 'infrastructure/**'
+      - '.github/workflows/deploy-*.yml'
+      - 'Dockerfile'
+      - 'pyproject.toml'
+      - 'uv.lock'
+      - 'src/**'
+    paths-ignore:
+      - 'README.md'
+      - 'CHANGELOG.md'
+      - 'CONTRIBUTING.md'
+      - 'docs/**'
+      - '*.md'
   workflow_dispatch:
     inputs:
       image_uri:
         description: Staging-validated immutable ECR URI ending in @sha256 digest
         required: true
         type: string
 permissions:
   contents: read
   id-token: write
 jobs:
   promote:
     runs-on: ubuntu-latest
     environment: production
     concurrency:  # <-- ADDED: Smart concurrency (safe for prod)
+      group: demo-command-center-production  # Keep simple group name for prod
+      cancel-in-progress: false              # Keep false for prod safety (don't cancel approved deploys)
     steps:
       - uses: actions/checkout@v4
       - name: Require immutable digest
         env: {IMAGE_URI: "${{ inputs.image_uri }}"}
         run: '[[ "$IMAGE_URI" =~ @sha256:[a-f0-9]{64}$ ]]'
       - uses: aws-actions/configure-aws-credentials@v4
         with:
           role-to-assume: ${{ secrets.AWS_ROLE_ARN }}
           aws-region: ${{ vars.AWS_REGION }}
       - uses: ./.github/actions/ecs-deploy
         with:
           image-uri: ${{ inputs.image_uri }}
           cluster: ${{ vars.ECS_CLUSTER }}
           api-service: ${{ vars.ECS_API_SERVICE }}
           worker-service: ${{ vars.ECS_WORKER_SERVICE }}
           task-definition-family: ${{ vars.ECS_API_TASK_FAMILY }}
           worker-task-definition-family: ${{ vars.ECS_WORKER_TASK_FAMILY }}
           migration-network-configuration: ${{ vars.ECS_MIGRATION_NETWORK_CONFIGURATION }}
           smoke-url: ${{ vars.SMOKE_BASE_URL }}
       - run: echo "Promoted ${{ inputs.image_uri }} to production after protected approval" >> "$GITHUB_STEP_SUMMARY"

   # ADDED: Add debugging step to monitor concurrency (optional but helpful)
   # Add this as first step in the promote job if you want to see queue status:
